APP_NAME=Draftly API
APP_VERSION=0.1.0
DEBUG=false

CORS_ORIGINS=["http://localhost:3000"]

VERIFY_GOOGLE_TOKEN=true
REQUIRED_GMAIL_SCOPE=https://www.googleapis.com/auth/gmail.modify

DEFAULT_MESSAGE_LIMIT=10
MAX_MESSAGE_LIMIT=50

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=draftly

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
EMAIL_POLL_INTERVAL_SECONDS=120

# Google OAuth (for backend token refresh in background tasks)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX=draftly-emails
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# AI provider: openai | anthropic | gemini
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
