APP_NAME=Draftly API
APP_VERSION=0.1.0
DEBUG=false

CORS_ORIGINS=["http://localhost:3000"]

VERIFY_GOOGLE_TOKEN=true
REQUIRED_GMAIL_SCOPE=https://www.googleapis.com/auth/gmail.modify

DEFAULT_MESSAGE_LIMIT=10
MAX_MESSAGE_LIMIT=50
MAX_SENT_BACKFILL=500
STYLE_CONTEXT_TOP_K=5

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=draftly

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
EMAIL_POLL_INTERVAL_SECONDS=120

# Google OAuth (for backend token refresh in background tasks)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX=draftly-emails
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# OpenRouter (OpenAI-compatible API for chat + embeddings)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1024
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Draftly
